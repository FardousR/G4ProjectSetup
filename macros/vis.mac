# ======================================================================
# Visualization macro for LETrix (Interactive Mode)
# ======================================================================

# ----------------------------------------------------------------------
# 1. Initialize Viewer
# ----------------------------------------------------------------------
# Open OpenGL (Standard). If you prefer ToolsSG, comment this and uncomment TSG.
/vis/open OGL 1200x1200-0+0
/vis/open TSG

# Disable auto-refresh and quieten messages while the scene is built
/vis/viewer/set/autoRefresh false
/vis/verbose errors

# ----------------------------------------------------------------------
# 2. Geometry & Styling
# ----------------------------------------------------------------------
# Draw the world volume and set the camera/lighting angles
/vis/drawVolume
/vis/viewer/set/viewpointVector -1 0 0
/vis/viewer/set/lightsVector -1 0 0
/vis/viewer/set/style surface

# Optional Geometry Coloring (Uncomment and adjust to your specific volumes)
# /vis/geometry/set/colour Target 0 0 0 1 0.5   # Blue, 50% transparent
# /vis/geometry/set/colour Grid 0 0 1 0 0.7     # Green, 70% transparent
# /vis/viewer/set/hiddenMarker true

# ----------------------------------------------------------------------
# 3. Trajectory Drawing
# ----------------------------------------------------------------------
# Draw smooth trajectories colored by particle charge, with 2px step markers
/vis/scene/add/trajectories smooth
/vis/modeling/trajectories/create/drawByCharge
/vis/modeling/trajectories/drawByCharge-0/default/setDrawStepPts true
/vis/modeling/trajectories/drawByCharge-0/default/setStepPtsSize 2

# ----------------------------------------------------------------------
# 4. Trajectory Filtering
# ----------------------------------------------------------------------
# Only show protons in the visualization (hides secondary electrons, gammas, etc.)
/vis/filtering/trajectories/create/particleFilter
/vis/filtering/trajectories/particleFilter-0/add proton

# ----------------------------------------------------------------------
# 5. Scene Accumulation & Finalization
# ----------------------------------------------------------------------
# Superimpose all events from a given run onto the same screen
/vis/scene/endOfEventAction accumulate

# Re-establish auto-refreshing and standard warnings to render the final image
/vis/viewer/set/autoRefresh true
/vis/verbose warnings